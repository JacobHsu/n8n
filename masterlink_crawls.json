    {
      "parameters": {
        "jsCode": "const raw = `\n6010,(牛牛牛)亞證券!6010,(牛牛牛)亞證券!6012,(牛牛牛)亞-網路!0036003000310064,(牛牛牛)亞-鑫豐;6620,口袋證券!6620,口袋證券;\n`;\n\nconst output = [];\nconst groups = raw.trim().split(';');\n\nfor (const group of groups) {\n  if (!group.trim()) continue;\n\n  const items = group.split('!');\n  let a = '';\n  let brokerName = '';\n  const bMap = new Map();\n\n  for (const item of items) {\n    const parts = item.split(',');\n    if (parts.length < 2) continue;\n    const code = parts[0].trim();\n    const name = parts[1].trim();\n\n    if (!a) {\n      a = code;\n      brokerName = name;\n    }\n\n    // 分點代碼與名稱\n    if (!bMap.has(code)) {\n      bMap.set(code, name);\n    }\n  }\n\n  for (const [b, branchName] of bMap.entries()) {\n    output.push({\n      a: a,\n      b: b,\n      url: `https://newjust.masterlink.com.tw/z/zg/zgb/zgb0.djhtm?a=${a}&b=${b}`,\n      券商名稱: brokerName,\n      分點名稱: branchName\n    });\n  }\n}\n\nreturn output.map(item => ({ json: item }));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -720,
        -360
      ],
      "id": "1b241e1d-dd26-497e-808c-612f82306818",
      "name": "Code"
