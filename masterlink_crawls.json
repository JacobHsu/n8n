      "name": "Extract from File"
    },
    {
      "parameters": {
        "jsCode": "const html = items[0].json.data;\n\n// 抓出所有 <table> 區塊\nconst tables = html.match(/<table[^>]*>[\\s\\S]*?<\\/table>/g);\nif (!tables) throw new Error('❌ 找不到任何 <table> 標籤');\n\n// 解析券商表格\nfunction parseSectionByKeyword(keyword) {\n  const result = [];\n\n  for (const table of tables) {\n    if (!table.includes(keyword)) continue;\n\n    const rows = table.split('</tr>').slice(2); // 跳過標題列\n    for (const row of rows) {\n      const cols = row.match(/<td.*?>([\\s\\S]*?)<\\/td>/g);\n      if (!cols || cols.length < 4) continue;\n\n      const scriptMatch = cols[0].match(/GenLink2stk\\('.*?','(.*?)'\\)/);\n      const name = scriptMatch ? scriptMatch[1] : cols[0].replace(/<.*?>/g, '').trim();\n\n      const buy = parseInt(cols[1].replace(/<.*?>/g, '').replace(/,/g, '').trim()) || 0;\n      const sell = parseInt(cols[2].replace(/<.*?>/g, '').replace(/,/g, '').trim()) || 0;\n      const diff = parseInt(cols[3].replace(/<.*?>/g, '').replace(/,/g, '').trim()) || 0;\n      if (name !== '券商名稱') {\n        result.push({\n          類型: keyword,\n          股票名稱: name,\n          買進金額: buy,\n          賣出金額: sell,\n          差額: diff\n        });\n      }\n    }\n\n    break; // 找到第一個含有該 keyword 的表格就停止\n  }\n\n  return result;\n}\n\n// 執行解析\nconst buyData = parseSectionByKeyword('買超');\nconst sellData = parseSectionByKeyword('賣超');\n\nconsole.log(`✅ 解析完成，共 ${buyData.length} 筆買超、${sellData.length} 筆賣超`);\n\nreturn [...buyData, ...sellData].map(d => ({ json: d }));\n"
      },
